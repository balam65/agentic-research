%%{init: {'themeVariables': { 'lineColor': '#ffffff' }}}%%
flowchart LR

    %% ── TRIGGER ──
    Client[🎯 Client Request<br>Chat / PDF / API / Brief]

    %% ── SETUP PATH (left side, top-down) ──
    subgraph SETUP ["🔧 SETUP PATH — Runs Once / On Break"]
        direction TB
        Master[Master Agent<br>Orchestration & State]
        Comp[Compliance Agent<br>Security & PII Rules]
        Assess[Assessment Agent<br>Intent → Research Brief]
        Sched[Scheduling Agent<br>SLA & Queue]
        Disc[Discovery Agent<br>Deep Links & APIs]
        SME[SME Agent<br>Feasibility & Evasion]
        Script[Scripting Agent<br>Selectors & Versioning]

        Master --> Comp
        Comp --> Assess
        Assess --> Sched
        Sched --> Disc
        Disc --> SME
        SME --> Script
    end

    %% ── PRODUCTION LOOP (right side, cycles) ──
    subgraph LOOP ["🔄 PRODUCTION LOOP — Runs Continuously"]
        direction TB
        Extr[Extraction Agent<br>Browser / HTTP / PDF]
        Scale[Production Agent<br>Proxies + Auto-Scale]
        Trans[Transformation Agent<br>Schema Normalization]
        QA[QA Agent<br>Confidence Scoring]
        Deliv[Delivery Agent<br>SFTP / S3 / API]
        Sent[Sentinel Agent<br>SLA & Alerts]
        Supp[Support Agent<br>Client Queries]

        Extr --> Scale
        Scale --> Trans
        Trans --> QA
        QA --> Deliv
        Deliv --> Sent
        Sent --> Supp
    end

    %% ── CONNECTIONS ──
    Client --> Master
    Script -- "✅ Script Ready" --> Extr
    Supp -- "🔄 Next Run" --> Extr

    %% ── REPAIR FEEDBACK ──
    Sent -. "🚨 Break / Drift" .-> Disc

    %% ── OUTPUT ──
    Deliv --> Output[🚀 Secure Delivered Dataset]

    %% ── STYLING ──
    classDef done fill:#22c55e,stroke:#166534,color:#fff,stroke-width:2px
    classDef progress fill:#eab308,stroke:#854d0e,color:#000,stroke-width:2px
    classDef gov fill:#64748b,stroke:#1e2937,color:#fff
    classDef output fill:#8b5cf6,stroke:#5b21b6,color:#fff,stroke-width:2px

    class Master,Comp gov
    class Assess,Sched,Disc,SME,Script,Trans,QA,Deliv,Sent,Supp done
    class Extr,Scale progress
    class Output output
