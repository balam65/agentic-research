  csv_converter --> delivery_trigger["Execute: Phase 5 Delivery"]

  classDef trigger fill:#00ff00,stroke:#333,color:#000;
  classDef agent fill:#0000ff,stroke:#333,color:#fff;
  classDef storage fill:#00ff00,stroke:#333,color:#000;
  classDef logic fill:#ff0000,stroke:#333,color:#fff;
  classDef alert fill:#ffff00,stroke:#333,color:#000;

  class trigger trigger;
  class normalizer util;
  class qa_agent agent;
  class quality_check logic;
  class slack_hitl alert;
  class csv_converter util;
  class delivery_trigger trigger;
