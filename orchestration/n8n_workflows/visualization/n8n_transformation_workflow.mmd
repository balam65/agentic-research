graph TD
  trigger["Sub-workflow Trigger"] --> normalizer["Code: Schema Normalizer"]
  normalizer --> qa_agent["AI Agent: QA & Validation"]
  
  qa_agent --> quality_check{"If: High Quality? (score >= 0.8)"}
